<script>
let currentLimit = 1;
let mySelection = []; // Храним объекты { r, s, el }

function changeLimit(step) {
    let next = currentLimit + step;
    if (next >= 1 && next <= 5) {
        currentLimit = next;
        document.getElementById('limitVal').innerText = currentLimit;
        // Если уменьшили — убираем лишнее
        while (mySelection.length > currentLimit) {
            const popped = mySelection.pop();
            popped.el.classList.remove('selected');
        }
        renderBadges();
    }
}

function renderBadges() {
    const container = document.getElementById('selectedBadges');
    if (mySelection.length === 0) {
        container.innerHTML = '<em style="color: #666;">места не выбраны</em>';
        return;
    }
    container.innerHTML = mySelection.map(item => 
        `<div class="seat-badge">Ряд ${item.r}, Место ${item.s}</div>`
    ).join('');
}

function book(time) {
    document.getElementById("seatingOverlay").style.display = "block";
    
    const grid = document.getElementById("seatsGrid");
    const labels = document.getElementById("rowLabels");
    grid.innerHTML = "";
    labels.innerHTML = "";
    mySelection = [];
    renderBadges();

    for (let r = 1; r <= 7; r++) {
        // Добавляем метку ряда слева
        const lbl = document.createElement("div");
        lbl.className = "row-num";
        lbl.innerText = "Ряд " + r;
        labels.appendChild(lbl);

        // Добавляем кресла
        for (let s = 1; s <= 15; s++) {
            const seat = document.createElement("div");
            seat.className = "seat-item";
            
            seat.onclick = function() {
                const idx = mySelection.findIndex(x => x.el === this);
                
                if (idx !== -1) {
                    this.classList.remove('selected');
                    mySelection.splice(idx, 1);
                } else {
                    if (mySelection.length < currentLimit) {
                        this.classList.add('selected');
                        mySelection.push({ r, s, el: this });
                    } else {
                        alert("Вы выбрали максимум мест (" + currentLimit + ")");
                    }
                }
                renderBadges();
            };
            grid.appendChild(seat);
        }
    }
}

function closeSeating() {
    document.getElementById("seatingOverlay").style.display = "none";
}

const TICKET_PRICE = 2500; // Цена одного билета в рублях/тенге

function confirmBooking() {
    // 1. ПРОВЕРКА АВТОРИЗАЦИИ
    if (btn.innerText === "Войти") {
        // Сначала ПРЯЧЕМ все открытые окна (зал и фильм)
        const seatingOverlay = document.getElementById("seatingOverlay");
        const cinemaOverlay = document.getElementById("cinemaOverlay"); // Универсальное окно фильма
        const moviePopup = document.querySelector(".cinema-flex-container");

        if (seatingOverlay) seatingOverlay.style.display = "none";
        if (cinemaOverlay) cinemaOverlay.style.display = "none";
        if (moviePopup) moviePopup.style.display = "none";

        // Теперь ОТКРЫВАЕМ только регистрацию
        modal.style.display = "block"; 
        
        alert("Для продолжения необходимо войти в аккаунт");
        return; // Останавливаем код, чтобы не открылась оплата
    }

    // 2. ПРОВЕРКА МЕСТ (если вошел)
    if (typeof mySelection === 'undefined' || mySelection.length === 0) {
        alert("Пожалуйста, выберите хотя бы одно место.");
        return;
    }

    // 3. ПЕРЕХОД К ОПЛАТЕ (если всё успешно)
    const seatingOverlay = document.getElementById("seatingOverlay");
    if (seatingOverlay) seatingOverlay.style.display = "none";

    const paymentOverlay = document.getElementById("paymentOverlay");
    if (paymentOverlay) {
        paymentOverlay.style.display = "flex";
        
        const price = typeof TICKET_PRICE !== 'undefined' ? TICKET_PRICE : 2500;
        const total = mySelection.length * price;
        
        const totalDisplay = document.getElementById("paymentTotal");
        if (totalDisplay) totalDisplay.innerText = total + " тг";
    }
}



let myTickets = []; 

// 1. Функция Оплаты
function processPayment() {
    const payBtn = document.getElementById("payBtn");
    if (!payBtn) return;

    payBtn.disabled = true;
    payBtn.innerText = "Обработка...";

    setTimeout(() => {
        // Собираем данные билета
        const movieTitle = document.getElementById("popupTitle")?.innerText || "Фильм";
        const movieImg = document.getElementById("dynamicPoster")?.src || "";
        const seatInfo = (typeof mySelection !== 'undefined' && mySelection.length > 0)
            ? mySelection.map(item => `Ряд ${item.r}, Место ${item.s}`).join('; ')
            : "Места не выбраны";

        const newTicket = {
            id: Math.floor(1000 + Math.random() * 9000),
            title: movieTitle,
            img: movieImg,
            details: seatInfo
        };

        // Сохраняем билет в массив (он сотрется при перезагрузке, если не использовать localStorage)
        // Чтобы билеты КРАТКОСРОЧНО выжили после перезагрузки, используем sessionStorage:
        let savedTickets = JSON.parse(sessionStorage.getItem('tempTickets') || "[]");
        savedTickets.push(newTicket);
        sessionStorage.setItem('tempTickets', JSON.stringify(savedTickets));

        alert("Оплата прошла! Сейчас вы вернетесь на главную.");
        
        // ГЛАВНЫЙ ШАГ: Полная перезагрузка страницы на главный экран
        window.location.reload(); 

    }, 1500);
}

// 2. Обновление списка (вызываем при загрузке страницы)
function updateTicketList() {
    const container = document.querySelector(".menu-content ul");
    if (!container) return;

    // Загружаем билеты из временного хранилища (чтобы они не пропадали после релоада)
    myTickets = JSON.parse(sessionStorage.getItem('tempTickets') || "[]");

    container.innerHTML = '<li><b>Мои билеты:</b></li>';

    myTickets.forEach((ticket, index) => {
        const li = document.createElement("li");
        li.style.cssText = "cursor:pointer; padding:10px 0; border-bottom:1px solid #eee; color:#962cf9;";
        li.innerText = `🎬 ${ticket.title}`;
        li.onclick = () => showTicket(index);
        container.appendChild(li);
    });
}

// 3. Показ билета
function showTicket(index) {
    const tickets = JSON.parse(sessionStorage.getItem('tempTickets') || "[]");
    const ticket = tickets[index];
    const overlay = document.getElementById("ticketOverlay");
    
    if (!ticket || !overlay) return;

    document.getElementById("ticketImg").src = ticket.img;
    document.getElementById("ticketTitle").innerText = ticket.title;
    document.getElementById("ticketDetails").innerText = ticket.details;
    document.getElementById("ticketID").innerText = ticket.id;

    overlay.style.display = "flex";
    if (typeof toggleMenu === 'function') toggleMenu();
}

// 4. Логика при загрузке (Проверяем логин и рисуем билеты)
window.addEventListener('load', () => {
    updateTicketList(); // Сразу рисуем билеты, если они были куплены

    const savedName = localStorage.getItem('userLoggedIn');
