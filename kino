    if (savedName && loginBtn) {
        loginBtn.innerText = "Выйти";
        const display = document.getElementById("display");
        if (display) {
            display.innerText = "Привет! " + savedName;
            display.style.display = "block";
        }
    }
});

// 5. Кнопка выхода (Кидает на главную)
const loginBtn = document.getElementById("loginBtn");
if (loginBtn) {
    loginBtn.onclick = function() {
        if (this.innerText === "Выйти") {
            localStorage.removeItem('userLoggedIn');
            sessionStorage.removeItem('tempTickets'); // Стираем билеты при выходе
            window.location.href = window.location.origin + window.location.pathname; // На главную
        } else {
            if (typeof openLoginModal === 'function') openLoginModal();
        }
    };
}


</script>


