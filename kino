<script>
const modal = document.getElementById("regModal");
const btn = document.getElementById("openReg");
const closeBtn = document.querySelector(".close-btn");

const form = modal.querySelector("form");
const input = modal.querySelector('input[type="text"]');
const display = document.getElementById("accountName");
const avatar = document.getElementById("userAvatar"); // Находим фото

btn.onclick = () => {
  if (btn.innerText === "Выйти") {
    btn.innerText = "Войти";
    display.innerText = "";
    display.style.display = "none";
    
    // Прячем и очищаем фото при выходе
    avatar.style.display = "none";
    avatar.src = "";
  } else {
    modal.style.display = "block";
  }
};

closeBtn.onclick = () => modal.style.display = "none";

form.onsubmit = (event) => {
  event.preventDefault(); 
  const name = input.value; 

  btn.innerText = "Выйти";
  display.innerText = "Привет! " + name; 
  display.style.display = "block"; 

  // ПОКАЗЫВАЕМ ФОТО
  avatar.src = "png-klev-club-2a76-p-tri-poloski-menyu-png-11.png"; // Замени на путь к своей картинке
  avatar.style.display = "block";

  modal.style.display = "none";
  form.reset();
};

function toggleMenu() {
    const menu = document.getElementById('leftMenu');
    menu.classList.toggle('active');
}

</script>
